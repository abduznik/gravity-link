{
    "name": "gravity-link-extension",
    "displayName": "Gravity Link",
    "description": "Mobile upload and voice-to-text bridge for Gravity",
    "icon": "icon.png",
    "version": "1.0.16",
    "mcpName": "io.github.cafeTechne/gravity-link",
    "files": [
        "out/**",
        "public/**",
        "icon.png",
        "README.md",
        "LICENSE"
    ],
    "license": "MIT",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "publisher": "cafetechne",
    "repository": {
        "type": "git",
        "url": "https://github.com/abduznik/gravity-link"
    },
    "activationEvents": [
        "onStartupFinished",
        "onCommand:gravity-link.start",
        "onCommand:gravity-link.selectNetworkInterface"
    ],
    "bin": "./out/standalone.js",
    "pkg": {
        "assets": [
            "public/**/*"
        ]
    },
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "gravity-link.start",
                "title": "Start Server",
                "category": "Gravity Link"
            },
            {
                "command": "gravity-link.stop",
                "title": "Stop Server",
                "category": "Gravity Link"
            },
            {
                "command": "gravity-link.showQR",
                "title": "Show QR Code",
                "category": "Gravity Link"
            },
            {
                "command": "gravity-link.selectNetworkInterface",
                "title": "Select Network Interface",
                "category": "Gravity Link"
            }
        ],
        "configuration": {
            "title": "Gravity Link",
            "properties": {
                "gravityLink.port": {
                    "type": "number",
                    "default": 3000,
                    "description": "%config.port.description%"
                },
                "gravityLink.autoStart": {
                    "type": "boolean",
                    "default": false,
                    "description": "%config.autoStart.description%"
                },
                "gravityLink.useHttps": {
                    "type": "boolean",
                    "default": false,
                    "description": "%config.useHttps.description%"
                },
                "gravityLink.preferredHost": {
                    "type": "string",
                    "default": "",
                    "description": "Preferred host IP address (e.g. your Tailscale IP) to bind and advertise."
                },
                "gravityLink.preferredNetworkInterface": {
                    "type": "string",
                    "default": "",
                    "description": "%config.preferredNetworkInterface.description%"
                },
                "gravityLink.strictWorkbenchOnly": {
                    "type": "boolean",
                    "default": true,
                    "description": "%config.strictWorkbenchOnly.description%"
                },
                "gravityLink.includeFallbackTargets": {
                    "type": "boolean",
                    "default": false,
                    "description": "%config.includeFallbackTargets.description%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run typecheck && npm run bundle",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "typecheck": "tsc -p ./ --noEmit",
        "bundle": "node ./esbuild.js",
        "package": "vsce package",
        "deploy": "npm run bundle && xcopy /Y out\\extension.js \"%USERPROFILE%\\.antigravity\\extensions\\cafetechne.gravity-link-extension-1.0.16\\out\\\" && xcopy /Y public\\index.html \"%USERPROFILE%\\.antigravity\\extensions\\cafetechne.gravity-link-extension-1.0.16\\public\\\"",
        "test": "mocha -r ts-node/register src/test/injectFile.test.ts src/test/injectMessage.test.ts src/test/isGeneratingTracker.test.ts src/test/scriptValidity.test.ts"
    },
    "devDependencies": {
        "@types/chai": "^5.2.3",
        "@types/express": "^4.17.21",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.12.7",
        "@types/qrcode": "^1.5.5",
        "@types/selfsigned": "^2.0.4",
        "@types/vscode": "^1.90.0",
        "@types/ws": "^8.5.10",
        "chai": "^6.2.2",
        "esbuild": "^0.20.2",
        "mocha": "^11.7.5",
        "playwright": "^1.59.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5",
        "vsce": "^2.15.0"
    },
    "dependencies": {
        "@types/multer": "^1.4.11",
        "express": "^4.19.2",
        "multer": "^1.4.5-lts.1",
        "qrcode": "^1.5.3",
        "selfsigned": "^2.4.1",
        "ws": "^8.16.0"
    }
}
